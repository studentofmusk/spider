    <!-- THIGH JOINTS -->
    <joint name="thigh_joint_1" type="revolute">
        <origin xyz="0.03816  -0.04816  0.01000" rpy="0.0 1.57 -0.785"/>
        <parent link="base"/>
        <child link="thigh1"/>
        <axis xyz="0 1 0"/>
        <limit lower="-1.57" upper="1.57" effort="5.0" velocity="1.0"/>
    </joint>
    <joint name="thigh_joint_2" type="revolute">
